{{! Organization Reference — DA faction tracker }}
<div class='org-reference-inner'>

  {{! ── Header ── }}
  <header class='org-ref-header'>
    <div class='header-left'>
      <h1 class='header-title'>{{localize 'NEONRELIC.OrgRef.Title'}}</h1>
      <div class='header-subtitle'>Neon Relic &mdash; The Verdant Covenant</div>
    </div>
    <div class='header-right'>
      <div class='classification'>{{localize 'NEONRELIC.CaseBrief.DAOnly'}}</div>
    </div>
  </header>

  {{! ── Organization Blocks ── }}
  {{#each organizations}}
    <div class='org-block {{this.statusClass}}'>
      <div class='org-block-header'>
        <strong class='org-name'>{{this.name}}</strong>
        <span class='org-value'>{{this.countdown}}/{{this.maxCountdown}}</span>
        <button type='button' data-action='toggleDormant' data-org-id='{{this.id}}' class='dormant-toggle'>
          {{#if this.dormant}}
            {{localize 'NEONRELIC.OrgRef.Activate'}}
          {{else}}
            {{localize 'NEONRELIC.OrgRef.SetDormant'}}
          {{/if}}
        </button>
      </div>

      {{! Milestone countdown boxes }}
      <div class='milestone-track'>
        {{#each this.milestoneBoxes}}
          <div class='{{this.boxClass}}'>
            {{this.number}}
          </div>
        {{/each}}
        <div class='milestone-controls'>
          <button
            type='button'
            data-action='retreatMilestone'
            data-org-id='{{this.id}}'
            class='milestone-btn'
          >&minus;</button>
          <button
            type='button'
            data-action='advanceMilestone'
            data-org-id='{{this.id}}'
            class='milestone-btn'
          >&plus;</button>
        </div>
      </div>

      {{! Milestones list }}
      {{#if this.milestones.length}}
        <div class='milestone-list'>
          {{#each this.milestones}}
            <div class='milestone-row'>
              <span class='milestone-val'>{{this.position}}</span>
              <span class='milestone-desc'>{{this.label}}</span>
            </div>
          {{/each}}
        </div>
      {{/if}}

      {{! Detail row }}
      <div class='org-detail-row'>
        {{#if this.activationCondition}}
          <div class='org-detail'>
            <span class='field-label'>{{localize 'NEONRELIC.OrgRef.ActivationCondition'}}</span>
            <div class='field-value'>{{this.activationCondition}}</div>
          </div>
        {{/if}}
        {{#if this.countdownGoal}}
          <div class='org-detail'>
            <span class='field-label'>{{localize 'NEONRELIC.OrgRef.Goal'}}</span>
            <div class='field-value'>{{this.countdownGoal}}</div>
          </div>
        {{/if}}
      </div>

      {{! Description }}
      {{#if this.description}}
        <div class='org-desc'>{{this.description}}</div>
      {{/if}}

      {{! Members }}
      {{#if this.members.length}}
        <div class='org-members'>
          <span class='field-label'>{{localize 'NEONRELIC.Case.KeyMembers'}}</span>
          {{#each this.members}}
            <span class='member'>{{this.name}} ({{this.role}})</span>
          {{/each}}
        </div>
      {{/if}}
    </div>
  {{/each}}

  {{! ── Footer ── }}
  <footer class='org-ref-footer'>
    <span>VC-20 &bull; The Verdant Covenant &bull; DA Use Only</span>
    <span>Neon Relic</span>
  </footer>
</div>