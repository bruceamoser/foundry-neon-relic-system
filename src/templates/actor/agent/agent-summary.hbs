<section class='tab summary {{tab.cssClass}}' data-group='primary' data-tab='summary'>

  {{! Identity Block }}
  <div class='collapsible-section {{#if (lookup collapsedSections 'identity')}}collapsed{{/if}}' data-section='identity'>
    <div class='section-title collapsible-toggle' data-action='toggleSection' data-section='identity'>
      {{localize 'NEONRELIC.Agent.Identity'}}
      <i class='fa-solid fa-chevron-{{#if (lookup collapsedSections 'identity')}}right{{else}}down{{/if}} collapsible-icon'></i>
    </div>
    <div class='collapsible-body'>
      <div class='id-block-row' style='grid-template-columns: 1.8fr 1fr 1.5fr;'>
        <div class='id-cell'>
          <span class='id-label'>{{localize 'NEONRELIC.Agent.Name'}}</span>
          <span class='id-value'>{{actor.name}}</span>
        </div>
        <div class='id-cell'>
          <span class='id-label'>{{localize 'NEONRELIC.Agent.Division'}}</span>
          <select class='id-value' name='system.division' {{disabled (not isEditable)}}>
            {{#each config.divisions as |label key|}}
              <option value='{{key}}' {{selected key @root.system.division}}>{{localize label}}</option>
            {{/each}}
          </select>
        </div>
        <div class='id-cell'>
          <span class='id-label'>{{localize 'NEONRELIC.Agent.SubUnit'}}</span>
          <input
            class='id-value'
            type='text'
            name='system.subUnit'
            value='{{system.subUnit}}'
            {{disabled (not isEditable)}}
          />
        </div>
      </div>
      <div class='id-block-row' style='grid-template-columns: 1fr 0.35fr 0.8fr 1fr;'>
        <div class='id-cell'>
          <span class='id-label'>{{localize 'NEONRELIC.Agent.Specialty'}}</span>
          <input
            class='id-value'
            type='text'
            name='system.specialty'
            value='{{system.specialty}}'
            {{disabled (not isEditable)}}
          />
        </div>
        <div class='id-cell'>
          <span class='id-label'>{{localize 'NEONRELIC.Agent.CL'}}</span>
          <input
            class='id-value'
            type='number'
            name='system.clearanceLevel'
            value='{{system.clearanceLevel}}'
            min='1'
            max='5'
            {{disabled (not isEditable)}}
          />
        </div>
        <div class='id-cell'>
          <span class='id-label'>{{localize 'NEONRELIC.Agent.Origin'}}</span>
          <input
            class='id-value'
            type='text'
            name='system.countryOfOrigin'
            value='{{system.countryOfOrigin}}'
            {{disabled (not isEditable)}}
          />
        </div>
        <div class='id-cell'>
          <span class='id-label'>{{localize 'NEONRELIC.Agent.DivisionItem'}}</span>
          <label class='id-value division-item-toggle'>
            <input
              type='checkbox'
              name='system.divisionItem.active'
              {{checked system.divisionItem.active}}
              {{disabled (not isEditable)}}
            />
            {{localize 'NEONRELIC.Agent.DivisionItemActive'}}
          </label>
        </div>
      </div>
      <div class='id-block-row' style='grid-template-columns: 1.5fr 0.5fr 1fr;'>
        <div class='id-cell'>
          <span class='id-label'>{{localize 'NEONRELIC.Agent.AgeGroup'}}</span>
          <select class='id-value' name='system.ageGroup' {{disabled (not isEditable)}}>
            {{#each config.ageGroups as |label key|}}
              <option value='{{key}}' {{selected key @root.system.ageGroup}}>{{localize label}}</option>
            {{/each}}
          </select>
        </div>
        <div class='id-cell'>
          <span class='id-label'>{{localize 'NEONRELIC.Agent.Age'}}</span>
          <input
            class='id-value'
            type='number'
            name='system.age'
            value='{{system.age}}'
            min='18'
            {{disabled (not isEditable)}}
          />
        </div>
        <div class='id-cell'></div>
      </div>
    </div>
  </div>

  {{! Quick Stats }}
  <div class='collapsible-section {{#if (lookup collapsedSections 'quickStats')}}collapsed{{/if}}' data-section='quickStats'>
    <div class='section-title collapsible-toggle' data-action='toggleSection' data-section='quickStats'>
      {{localize 'NEONRELIC.Agent.QuickStats'}}
      <i class='fa-solid fa-chevron-{{#if (lookup collapsedSections 'quickStats')}}right{{else}}down{{/if}} collapsible-icon'></i>
    </div>
    <div class='collapsible-body'>
      <div class='attr-grid'>
        {{#each attrColumns}}
          <div class='stat-box rollable' data-action='rollAttribute' data-attribute='{{this.key}}'>
            <span class='stat-label'>{{localize this.label}}</span>
            {{#if this.isDamaged}}
              <span class='stat-value stat-value--damaged'>{{this.value}}<span
                  class='stat-value__max'
                >/{{this.max}}</span></span>
            {{else}}
              <span class='stat-value'>{{this.value}}</span>
            {{/if}}
          </div>
        {{/each}}
      </div>
      {{! Build Point Warnings }}
      {{#if buildWarnings.hasWarnings}}
        <div class='build-warnings'>
          {{#if buildWarnings.attrDiff}}
            <div class='build-warning {{buildWarnings.attrClass}}'>
              <i class='fa-solid {{buildWarnings.attrIcon}}'></i>
              {{localize 'NEONRELIC.Budget.Attributes'}}:
              {{buildWarnings.attrDiffText}}
            </div>
          {{/if}}
          {{#if buildWarnings.skillDiff}}
            <div class='build-warning {{buildWarnings.skillClass}}'>
              <i class='fa-solid {{buildWarnings.skillIcon}}'></i>
              {{localize 'NEONRELIC.Budget.Skills'}}:
              {{buildWarnings.skillDiffText}}
            </div>
          {{/if}}
        </div>
      {{/if}}
    </div>
  </div>

  {{! Skills }}
  <div class='section-title'>{{localize 'NEONRELIC.Agent.Skills'}}</div>
  <div class='summary-skills'>
    {{#each attrColumns}}
      <div class='summary-skill-group'>
        <div class='summary-skill-attr'>{{localize this.label}}</div>
        {{#each this.skills}}
          <div class='summary-skill-row rollable' data-action='rollSkill' data-skill='{{this.key}}'>
            <span class='summary-skill-name'>{{localize this.label}}</span>
            <span class='summary-skill-value'>{{this.value}}</span>
          </div>
        {{/each}}
      </div>
    {{/each}}
  </div>

  {{! Corruption Summary }}
  <div class='corruption-summary'>
    <span class='corruption-summary__label'>{{localize 'NEONRELIC.Corruption.Label'}}</span>
    <span class='corruption-summary__value' data-stage='{{corruptionStage}}'>
      {{system.corruption.value}}
      /
      {{system.corruption.threshold}}
    </span>
    <span class='corruption-summary__stage'>{{localize (concat 'NEONRELIC.CorruptionStage.' corruptionStage)}}</span>
  </div>

  {{! Conditions }}
  {{#if anchor}}
    <div class='section-title green'>{{localize 'NEONRELIC.ItemType.anchor'}}</div>
    <div class='summary-anchor'>
      <span class='summary-anchor-name'>{{anchor.name}}</span>
      <span class='summary-anchor-uses'>{{anchor.system.uses.value}} / {{anchor.system.uses.max}}</span>
      {{#if anchor.system.isLost}}
        <span class='lost-badge'>{{localize 'NEONRELIC.Anchor.Lost'}}</span>
      {{/if}}
      {{#if (and @root.isEditable (not anchor.system.isLost) (gt anchor.system.uses.value 0))}}
        <button
          type='button'
          class='anchor-use-btn'
          data-action='useAnchor'
          data-item-id='{{anchor.id}}'
          title='{{localize "NEONRELIC.Anchor.UseHint"}}'
        >
          <i class='fa-solid fa-anchor'></i>
          {{localize 'NEONRELIC.Anchor.Use'}}
        </button>
      {{/if}}
    </div>
  {{/if}}

  {{! Conditions }}
  {{#if system.conditions.isBroken}}
    <div class='danger-box condition-alert'>{{localize 'NEONRELIC.Condition.Broken'}}</div>
  {{/if}}
  {{#if system.conditions.isDying}}
    <div class='danger-box condition-alert condition-alert--lethal'>{{localize 'NEONRELIC.Condition.Dying'}}</div>
  {{/if}}
</section>