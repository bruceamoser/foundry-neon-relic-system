<section class='tab talents {{tab.cssClass}}' data-group='primary' data-tab='talents'>
  <div class='section-title green'>{{localize 'NEONRELIC.Tab.Talents'}}</div>
  <div class='three-col talent-grid'>
    {{#each talents}}
      <div class='talent-block' data-item-id='{{this.id}}'>
        <div class='talent-header'>
          <div class='talent-type'>{{this.system.talentType}}</div>
          {{#if @root.isEditable}}
            <button
              type='button'
              class='remove-btn'
              data-action='removeItem'
              data-item-id='{{this.id}}'
              title='{{localize "NEONRELIC.Item.Remove"}}'
            >
              <i class='fa-solid fa-trash'></i>
            </button>
          {{/if}}
        </div>
        <a class='talent-name item-name' data-action='viewItem'>{{this.name}}</a>
        <div class='talent-meta'>
          <span class='talent-frequency {{this.system.frequency}}'>
            {{#if (eq this.system.frequency 'at-will')}}{{localize 'NEONRELIC.Talent.FrequencyAtWill'}}
            {{else if (eq this.system.frequency 'per-session')}}{{localize 'NEONRELIC.Talent.FrequencyPerSession'}}
            {{else if (eq this.system.frequency 'per-case-file')}}{{localize 'NEONRELIC.Talent.FrequencyPerCaseFile'}}
            {{else}}{{this.system.frequency}}
            {{/if}}
          </span>
          {{#if (eq this.system.frequency 'per-session')}}
            <span class='talent-uses'>{{this.system.usesPerSession.value}} / {{this.system.usesPerSession.max}}</span>
          {{/if}}
          {{#if (eq this.system.frequency 'per-case-file')}}
            <span class='talent-uses'>{{this.system.usesPerCaseFile.value}} / {{this.system.usesPerCaseFile.max}}</span>
          {{/if}}
          {{#if this.system.hasHealingTag}}
            <span class='healing-tag' title='{{localize "NEONRELIC.Talent.HealingTag"}}'>&#9829;</span>
          {{/if}}
          {{#if this.system.corruptionCost}}
            <span class='corruption-cost'>&#9760; {{this.system.corruptionCost}}</span>
          {{/if}}
        </div>
        {{#if @root.isEditable}}
          <button type='button' class='talent-use-btn' data-action='useTalent'>
            <i class='fa-solid fa-bolt'></i>
            {{localize 'NEONRELIC.Talent.Use'}}
          </button>
        {{/if}}
      </div>
    {{/each}}
  </div>
  {{#unless talents.length}}
    <p class='empty-list'>{{localize 'NEONRELIC.NoItems'}}</p>
  {{/unless}}
  {{#if isEditable}}
    <div class='add-buttons-row'>
      {{#if canAddTalent}}
        <button type='button' class='add-btn' data-action='addTalent'>+
          {{localize 'NEONRELIC.Agent.AddTalent'}}</button>
      {{else}}
        <button type='button' class='add-btn' disabled title='{{talentCostHint}}'>+
          {{localize 'NEONRELIC.Agent.AddTalent'}}</button>
      {{/if}}
      {{#if talentCount}}
        <span class='add-hint'>{{talentCostHint}}</span>
      {{/if}}
    </div>
  {{/if}}
</section>