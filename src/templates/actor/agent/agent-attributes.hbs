<section class='tab attributes' data-group='primary' data-tab='attributes'>
  <div class='section-title'>{{localize 'NEONRELIC.Tab.Attributes'}} &amp; {{localize 'NEONRELIC.Agent.Skills'}}</div>

  <div class='attr-skill-grid'>
    {{#each attrColumns}}
      <div class='attr-skill-col'>

        {{! Attribute box }}
        <div class='attr-box'>
          <div class='attr-name'>{{localize this.label}}</div>
          <div class='attr-score'>
            <input
              type='number'
              name='system.attributes.{{this.key}}.value'
              value='{{this.value}}'
              min='0'
              {{disabled (not @root.isEditable)}}
            />
          </div>
          <div class='attr-max'>
            max
            <input
              type='number'
              name='system.attributes.{{this.key}}.max'
              value='{{this.max}}'
              min='0'
              {{disabled (not @root.isEditable)}}
            />
          </div>
          <div class='attr-dmg-label'>{{localize this.damageLabel}}</div>
          <div class='attr-dmg-track'>
            {{#each this.damagePips}}
              <div class='{{this.cssClass}}'></div>
            {{/each}}
          </div>
          <button type='button' class='attr-roll-btn' data-action='rollAttribute' data-attribute='{{this.key}}'>
            <i class='fa-solid fa-dice-d6'></i>
          </button>
        </div>

        {{! Skill area }}
        <div class='skill-area'>
          <div class='skill-area-header'>{{localize 'NEONRELIC.Agent.Skills'}}</div>
          {{#each this.skills}}
            <div class='skill-row'>
              <button type='button' class='skill-roll-btn' data-action='rollSkill' data-skill='{{this.key}}'>
                <i class='fa-solid fa-dice-d6'></i>
              </button>
              <span class='skill-name'>{{localize this.label}}</span>
              <input
                type='number'
                class='skill-value'
                name='system.skills.{{this.key}}'
                value='{{this.value}}'
                min='0'
                max='5'
                {{disabled (not @root.isEditable)}}
              />
            </div>
          {{/each}}
        </div>

      </div>
    {{/each}}
  </div>
</section>