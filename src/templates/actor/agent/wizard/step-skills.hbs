{{! Step 7: Distribute Skill Points }}
<div class='wizard-step-skills'>
  <p class='step-description'>
    {{skillsDescription}}
  </p>

  <div class='budget-display'>
    <span class='budget-label'>{{localize 'NEONRELIC.Wizard.Skills.Budget'}}</span>
    <span class='budget-value {{skillBudgetClass}}'>{{skillBudget.skillSpent}} / {{skillBudget.skillTotal}}</span>
  </div>

  {{#if keySkillName}}
    <p class='key-skill-note'>
      <i class='fa-solid fa-star key-skill-star'></i>
      {{localize 'NEONRELIC.Wizard.Skills.KeySkillNote'}}:
      <strong>{{keySkillName}}</strong>
    </p>
  {{/if}}

  <div class='skills-columns'>
    {{#each skillColumns as |col|}}
      <div class='skill-column'>
        <div class='skill-column-header'>
          <span class='attr-name'>{{col.attrLabel}}</span>
          <span class='attr-val'>({{col.attrValue}})</span>
        </div>
        {{#each col.skills as |skill|}}
          <div class='skill-row {{skill.cssClass}}'>
            <label>
              {{#if skill.isKeySkill}}
                <i class='fa-solid fa-star key-skill-star'></i>
              {{/if}}
              {{skill.label}}
            </label>
            <div class='adjust-controls'>
              <button
                type='button'
                data-action='adjustWizardSkill'
                data-skill='{{skill.key}}'
                data-delta='-1'
                {{skill.disabledMinus}}
              ><i class='fa-solid fa-minus'></i></button>
              <span class='skill-value'>{{skill.value}}</span>
              <button
                type='button'
                data-action='adjustWizardSkill'
                data-skill='{{skill.key}}'
                data-delta='1'
                {{skill.disabledPlus}}
              ><i class='fa-solid fa-plus'></i></button>
            </div>
          </div>
        {{/each}}
      </div>
    {{/each}}
  </div>
</div>