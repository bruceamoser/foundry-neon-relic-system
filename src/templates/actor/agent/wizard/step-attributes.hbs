{{! Step 6: Distribute Attribute Points }}
<div class='wizard-step-attributes'>
  <p class='step-description'>
    {{localize 'NEONRELIC.Wizard.Attributes.Description'}}
  </p>

  {{#if keyAttrName}}
    <p class='key-skill-note'>
      <i class='fa-solid fa-star'></i>
      <strong>{{keyAttrName}}</strong>
      {{localize 'NEONRELIC.Wizard.Attributes.KeyNote'}}
    </p>
  {{/if}}

  <div class='budget-display'>
    <span class='budget-label'>{{localize 'NEONRELIC.Wizard.Attributes.Budget'}}</span>
    <span class='budget-value {{budgetClass}}'>{{attrBudget.attrSpent}}
      /
      {{attrBudget.attrTotal}}</span>
  </div>

  <div class='attributes-grid'>
    {{#each attributes as |attr|}}
      <div class='attribute-row {{attr.cssClass}}'>
        <label for='attr-{{attr.key}}'>
          {{#if attr.isKeyAttr}}
            <i class='fa-solid fa-star key-attr-star'></i>
          {{/if}}
          {{attr.label}}
        </label>
        <div class='adjust-controls'>
          <button
            type='button'
            data-action='adjustWizardAttribute'
            data-attr='{{attr.key}}'
            data-delta='-1'
            {{attr.disabledMinus}}
          ><i class='fa-solid fa-minus'></i></button>
          <span class='attr-value'>{{attr.value}}</span>
          <button
            type='button'
            data-action='adjustWizardAttribute'
            data-attr='{{attr.key}}'
            data-delta='1'
            {{attr.disabledPlus}}
          ><i class='fa-solid fa-plus'></i></button>
        </div>
      </div>
    {{/each}}
  </div>
</div>