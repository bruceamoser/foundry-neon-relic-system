{{! Location item type template — matches location-page.html }}
<div class='location-sheet'>
  {{! Location ID Badge }}
  <div class='loc-id-row'>
    <div class='loc-id'>LOC</div>
  </div>

  {{! Availability }}
  <div class='section-title green'>
    {{localize 'NEONRELIC.Location.Availability'}}
  </div>
  <div class='avail-row'>
    <select name='system.availability' class='avail-select' {{disabled (not isEditable)}}>
      <option value='open' {{selected system.availability 'open'}}>
        {{localize 'NEONRELIC.Location.Open'}}
      </option>
      <option value='clue' {{selected system.availability 'clue'}}>
        {{localize 'NEONRELIC.Location.Clue'}}
      </option>
      <option value='contact' {{selected system.availability 'contact'}}>
        {{localize 'NEONRELIC.Location.Contact'}}
      </option>
      <option value='time' {{selected system.availability 'time'}}>
        {{localize 'NEONRELIC.Location.Time'}}
      </option>
      <option value='packet' {{selected system.availability 'packet'}}>
        {{localize 'NEONRELIC.Location.Packet'}}
      </option>
    </select>
  </div>
  <div class='field'>
    <span class='field-label'>
      {{localize 'NEONRELIC.Location.AvailabilityCondition'}}
    </span>
    <input
      class='field-value'
      type='text'
      name='system.availabilityCondition'
      value='{{system.availabilityCondition}}'
      {{disabled (not isEditable)}}
    />
  </div>

  {{! NPCs Present }}
  <div class='section-title'>
    {{localize 'NEONRELIC.Location.NPCsPresent'}}
  </div>
  <div class='field'>
    <span class='field-label'>
      {{localize 'NEONRELIC.Location.NPCsPresentHint'}}
    </span>
    <div class='field-value med editor'>{{{enrichedNpcsPresent}}}</div>
  </div>

  {{! Information Available }}
  <div class='section-title green'>
    {{localize 'NEONRELIC.Location.InformationAvailable'}}
  </div>
  <div class='field'>
    <span class='field-label'>
      {{localize 'NEONRELIC.Location.InformationHint'}}
    </span>
    <div class='field-value med editor'>{{{enrichedInformationAvailable}}}</div>
  </div>

  {{! Organizations Present }}
  <div class='section-title'>
    {{localize 'NEONRELIC.Location.OrganizationsPresent'}}
  </div>
  <div class='field'>
    <span class='field-label'>
      {{localize 'NEONRELIC.Location.OrganizationsHint'}}
    </span>
    <div class='field-value editor'>{{{enrichedOrganizationsPresent}}}</div>
  </div>

  {{! Engagement Results }}
  <div class='section-title red'>
    {{localize 'NEONRELIC.Location.EngagementResults'}}
  </div>
  <div class='result-grid'>
    <div class='result-col'>
      <span class='field-label'>
        {{localize 'NEONRELIC.Location.PositiveResult'}}
      </span>
      <div class='field-value tall editor'>
        {{{enrichedPositiveResult}}}
      </div>
    </div>
    <div class='result-col'>
      <span class='field-label'>
        {{localize 'NEONRELIC.Location.NegativeResult'}}
      </span>
      <div class='field-value tall editor'>
        {{{enrichedNegativeResult}}}
      </div>
    </div>
  </div>

  {{! Milestone Changes }}
  <div class='section-title'>
    {{localize 'NEONRELIC.Location.MilestoneChanges'}}
  </div>
  <div class='field'>
    <span class='field-label'>
      {{localize 'NEONRELIC.Location.MilestoneHint'}}
    </span>
    <div class='field-value tall editor'>
      {{{enrichedMilestoneChanges}}}
    </div>
  </div>
</div>