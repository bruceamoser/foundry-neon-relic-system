{{! Artifact item type template — matches relic-sheet.html }}
<div class='artifact-sheet'>
  {{! Relic Identity Grid }}
  <div class='relic-id-grid'>
    <div class='id-block-row four-col'>
      <div class='id-cell'>
        <span class='id-label'>{{localize 'NEONRELIC.Artifact.Tier'}}</span>
        <select name='system.tier' class='id-value' {{disabled (not isEditable)}}>
          <option value='1' {{selected system.tier 1}}>1</option>
          <option value='2' {{selected system.tier 2}}>2</option>
          <option value='3' {{selected system.tier 3}}>3</option>
        </select>
      </div>
      <div class='id-cell'>
        <span class='id-label'>
          {{localize 'NEONRELIC.Artifact.CorruptionCost'}}
        </span>
        <span class='id-value corruption-cost'>{{system.corruptionCost}}</span>
      </div>
      <div class='id-cell'>
        <span class='id-label'>
          {{localize 'NEONRELIC.Artifact.ArtifactDie'}}
        </span>
        <span class='id-value die-display'>
          {{system.artifactDie.current}}
          {{#if isEditable}}
            <button type='button' class='die-step-btn' data-action='stepDownArtifact'>
              <i class='fa-solid fa-arrow-down'></i>
            </button>
          {{/if}}
        </span>
      </div>
      <div class='id-cell'>
        <span class='id-label'>{{localize 'NEONRELIC.Encumbrance'}}</span>
        <span class='id-value'>{{system.encumbrance}}</span>
      </div>
    </div>
  </div>

  {{! Status Flags }}
  <div class='relic-flags'>
    <label class='relic-flag'>
      <input
        type='checkbox'
        name='system.isActivatedThisCase'
        {{checked system.isActivatedThisCase}}
        {{disabled (not isEditable)}}
      />
      {{localize 'NEONRELIC.Artifact.Activated'}}
    </label>
    <label class='relic-flag'>
      <input
        type='checkbox'
        name='system.containmentProfile.isContained'
        {{checked system.containmentProfile.isContained}}
        {{disabled (not isEditable)}}
      />
      {{localize 'NEONRELIC.Artifact.Contained'}}
    </label>
    <label class='relic-flag'>
      <input
        type='checkbox'
        name='system.loreIdentified'
        {{checked system.loreIdentified}}
        {{disabled (not isEditable)}}
      />
      {{localize 'NEONRELIC.Artifact.Identified'}}
    </label>
    <label class='relic-flag'>
      <input
        type='checkbox'
        name='system.activePressure'
        {{checked system.activePressure}}
        {{disabled (not isEditable)}}
      />
      {{localize 'NEONRELIC.Artifact.ActivePressure'}}
    </label>
    <label class='relic-flag'>
      <input type='checkbox' name='system.replicable' {{checked system.replicable}} {{disabled (not isEditable)}} />
      {{localize 'NEONRELIC.Artifact.Replicable'}}
    </label>
  </div>

  {{! Activation & Effect }}
  <div class='section-title'>
    {{localize 'NEONRELIC.Artifact.ActivationAndEffect'}}
  </div>
  <div class='field-row'>
    <div class='field'>
      <span class='field-label'>
        {{localize 'NEONRELIC.Artifact.Activation'}}
      </span>
      <input
        class='field-value med'
        type='text'
        name='system.activationCondition'
        value='{{system.activationCondition}}'
        {{disabled (not isEditable)}}
      />
    </div>
    <div class='field'>
      <span class='field-label'>{{localize 'NEONRELIC.Artifact.Effect'}}</span>
      <div class='field-value med editor'>{{{enrichedEffect}}}</div>
    </div>
  </div>

  {{! Fracture }}
  <div class='danger-box'>
    <span class='field-label'>
      {{localize 'NEONRELIC.Artifact.FractureCondition'}}
    </span>
    <input
      class='field-value med'
      type='text'
      name='system.fractureCondition'
      value='{{system.fractureCondition}}'
      {{disabled (not isEditable)}}
    />
  </div>

  {{! Emission }}
  <div class='section-title'>{{localize 'NEONRELIC.Artifact.Emission'}}</div>
  <div class='field-row'>
    <div class='field'>
      <span class='field-label'>
        {{localize 'NEONRELIC.Artifact.EmissionType'}}
      </span>
      <input
        class='field-value'
        type='text'
        name='system.emission.type'
        value='{{system.emission.type}}'
        {{disabled (not isEditable)}}
      />
    </div>
    <div class='field'>
      <span class='field-label'>
        {{localize 'NEONRELIC.Artifact.EmissionRadius'}}
      </span>
      <input
        class='field-value'
        type='text'
        name='system.emission.radius'
        value='{{system.emission.radius}}'
        {{disabled (not isEditable)}}
      />
    </div>
    <div class='field'>
      <span class='field-label'>
        {{localize 'NEONRELIC.Artifact.EmissionTrigger'}}
      </span>
      <input
        class='field-value'
        type='text'
        name='system.emission.trigger'
        value='{{system.emission.trigger}}'
        {{disabled (not isEditable)}}
      />
    </div>
  </div>
  <div class='field-row'>
    <div class='field'>
      <span class='field-label'>
        {{localize 'NEONRELIC.Artifact.EmissionCorruption'}}
      </span>
      <input
        class='field-value'
        type='number'
        name='system.emission.corruptionAmount'
        value='{{system.emission.corruptionAmount}}'
        min='0'
        {{disabled (not isEditable)}}
      />
    </div>
    <div class='field'>
      <label class='relic-flag inline'>
        <input
          type='checkbox'
          name='system.emission.isSuppressed'
          {{checked system.emission.isSuppressed}}
          {{disabled (not isEditable)}}
        />
        {{localize 'NEONRELIC.Artifact.Suppressed'}}
      </label>
    </div>
  </div>

  {{! Containment Profile }}
  <div class='section-title red'>
    {{localize 'NEONRELIC.Artifact.Containment'}}
  </div>
  <div class='field'>
    <span class='field-label'>
      {{localize 'NEONRELIC.Artifact.ContainmentType'}}
    </span>
    <input
      class='field-value med'
      type='text'
      name='system.containmentProfile.type'
      value='{{system.containmentProfile.type}}'
      {{disabled (not isEditable)}}
    />
  </div>

  {{! Containment Truths }}
  <div class='section-title red'>
    {{localize 'NEONRELIC.Artifact.ContainmentTruths'}}
  </div>
  <div class='truth-grid'>
    <div class='truth-entry'>
      <span class='field-label'>
        {{localize 'NEONRELIC.Artifact.TriggerCondition'}}
      </span>
      <input
        class='field-value'
        type='text'
        name='system.containmentProfile.truths.triggerCondition'
        value='{{system.containmentProfile.truths.triggerCondition}}'
        {{disabled (not isEditable)}}
      />
    </div>
    <div class='truth-entry'>
      <span class='field-label'>
        {{localize 'NEONRELIC.Artifact.Appetite'}}
      </span>
      <input
        class='field-value'
        type='text'
        name='system.containmentProfile.truths.appetite'
        value='{{system.containmentProfile.truths.appetite}}'
        {{disabled (not isEditable)}}
      />
    </div>
    <div class='truth-entry'>
      <span class='field-label'>
        {{localize 'NEONRELIC.Artifact.Quiescence'}}
      </span>
      <input
        class='field-value'
        type='text'
        name='system.containmentProfile.truths.quiescenceCondition'
        value='{{system.containmentProfile.truths.quiescenceCondition}}'
        {{disabled (not isEditable)}}
      />
    </div>
  </div>
</div>