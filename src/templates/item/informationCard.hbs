{{! Information Card item sheet — front/back reveal card }}
<div class='info-card-sheet {{cardTypeClass}}'>

  {{! ── Card Front ── }}
  <div class='card-front'>
    <div class='card-header-row'>
      <div class='card-id'>{{system.cardId}}</div>
      <div class='card-label'>{{localize 'NEONRELIC.InfoCard.Label'}}</div>
    </div>
    <div class='card-type-label'>
      {{#if isTruth}}
        {{localize 'NEONRELIC.InfoCard.ContainmentTruth'}}
      {{else}}
        {{localize 'NEONRELIC.InfoCard.SupportingIntel'}}
      {{/if}}
    </div>
    <div class='content-area'>{{{enrichedContent}}}</div>
  </div>

  {{! ── Card Back (DA details) ── }}
  <div class='card-back'>
    <div class='back-header'>
      <span class='back-title'>{{localize 'NEONRELIC.InfoCard.DAReference'}}</span>
      <span class='back-stamp'>{{localize 'NEONRELIC.CaseBrief.DAOnly'}}</span>
    </div>

    <div class='back-fields'>
      <div class='back-field'>
        <label class='field-label'>{{localize 'NEONRELIC.InfoCard.CardId'}}</label>
        <input type='text' name='system.cardId' value='{{system.cardId}}' />
      </div>
      <div class='back-field'>
        <label class='field-label'>{{localize 'NEONRELIC.InfoCard.CardType'}}</label>
        <select name='system.cardType'>
          {{selectOptions cardTypeChoices selected=system.cardType}}
        </select>
      </div>
      <div class='back-field'>
        <label class='field-label'>{{localize 'NEONRELIC.InfoCard.FoundAt'}}</label>
        <input type='text' name='system.foundAt' value='{{system.foundAt}}' />
      </div>
      <div class='back-field'>
        <label class='field-label'>{{localize 'NEONRELIC.InfoCard.KnownBy'}}</label>
        <input type='text' name='system.knownBy' value='{{system.knownBy}}' />
      </div>
      <div class='back-field'>
        <label class='field-label'>{{localize 'NEONRELIC.InfoCard.HQFallback'}}</label>
        <input type='number' name='system.hqFallback' value='{{system.hqFallback}}' min='0' />
      </div>
    </div>

    <div class='back-content'>
      <label class='field-label'>{{localize 'NEONRELIC.InfoCard.Content'}}</label>
      {{formInput (formField system.fields.content value=system.content) name='system.content' type='prosemirror'}}
    </div>
  </div>
</div>