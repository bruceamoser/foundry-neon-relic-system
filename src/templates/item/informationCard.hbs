{{! Information Card item sheet — double-sided card layout }}
{{! Front = player-facing / Back = DA-facing }}

<div class='info-card-sheet {{cardTypeClass}}'>

  {{! ── Card Front (Player-Facing) ── }}
  <div class='card-front'>
    <div class='card-header-row'>
      <div class='card-id'>{{system.cardId}}</div>
      <div class='card-label'>{{localize 'NEONRELIC.InfoCard.Label'}}</div>
    </div>
    {{#if isTruth}}
      <div class='card-type-label'>{{localize 'NEONRELIC.InfoCard.ContainmentTruth'}}</div>
    {{/if}}
    <div class='content-area'>
      {{#if system.revealed}}
        {{#if isEditable}}
          <prose-mirror
            name='system.content'
            value='{{system.content}}'
            data-document-uuid='{{document.uuid}}'
            relative
          ></prose-mirror>
        {{else}}
          {{{enrichedContent}}}
        {{/if}}
      {{else}}
        <div class='content-hidden'><em>{{localize 'NEONRELIC.InfoCard.RevealedHint'}}</em></div>
      {{/if}}
    </div>
    <div class='card-footer'>{{localize 'NEONRELIC.InfoCard.Footer'}}</div>
  </div>

  {{! ── Card Back (DA-Facing) — GM only ── }}
  {{#if user.isGM}}
    <div class='card-back'>
      <div class='back-header'>
        <span class='back-title'>{{localize 'NEONRELIC.InfoCard.DAReference'}}</span>
        <span class='back-stamp'>{{localize 'NEONRELIC.InfoCard.DAEyesOnly'}}</span>
      </div>

      {{! ── Tab Navigation ── }}
      <nav class='info-tabs tabs' data-group='info-primary'>
        <a class='item active' data-tab='details' data-group='info-primary'>{{localize
            'NEONRELIC.InfoCard.TabDetails'
          }}</a>
        <a class='item' data-tab='knownBy' data-group='info-primary'>{{localize 'NEONRELIC.InfoCard.KnownBy'}}
          ({{linkedKnownBy.length}})</a>
        <a class='item' data-tab='foundAt' data-group='info-primary'>{{localize 'NEONRELIC.InfoCard.FoundAt'}}
          ({{linkedFoundAt.length}})</a>
      </nav>

      {{! ── Tab Content ── }}
      <div class='info-tab-content'>
        {{! Details Tab }}
        <div class='tab active' data-tab='details' data-group='info-primary'>
          <div class='back-field'>
            <label class='field-label'>{{localize 'NEONRELIC.InfoCard.CardId'}}</label>
            <input
              type='text'
              name='system.cardId'
              value='{{system.cardId}}'
              placeholder='{{localize "NEONRELIC.InfoCard.CardIdHint"}}'
              {{disabled (not isEditable)}}
            />
          </div>

          <div class='back-field card-type-field'>
            <label class='field-label'>{{localize 'NEONRELIC.InfoCard.CardType'}}</label>
            <div class='radio-group'>
              <label class='radio-label'>
                <input
                  type='radio'
                  name='system.cardType'
                  value='supportingIntel'
                  {{checked (eq system.cardType 'supportingIntel')}}
                  {{disabled (not isEditable)}}
                />
                {{localize 'NEONRELIC.InfoCard.SupportingIntel'}}
              </label>
              <label class='radio-label'>
                <input
                  type='radio'
                  name='system.cardType'
                  value='containmentTruth'
                  {{checked (eq system.cardType 'containmentTruth')}}
                  {{disabled (not isEditable)}}
                />
                {{localize 'NEONRELIC.InfoCard.ContainmentTruth'}}
              </label>
            </div>
          </div>

          <div class='back-field'>
            <label class='field-label'>{{localize 'NEONRELIC.InfoCard.HQFallback'}}</label>
            <input
              type='number'
              name='system.hqFallback'
              value='{{system.hqFallback}}'
              min='0'
              placeholder='{{localize "NEONRELIC.InfoCard.HQFallbackHint"}}'
              {{disabled (not isEditable)}}
            />
          </div>

          <div class='back-content'>
            <label class='field-label'>{{localize 'NEONRELIC.InfoCard.DANotes'}}</label>
            <span class='field-hint'>{{localize 'NEONRELIC.InfoCard.DANotesHint'}}</span>
            {{#if isEditable}}
              <prose-mirror
                name='system.daNotes'
                value='{{system.daNotes}}'
                data-document-uuid='{{document.uuid}}'
                relative
              ></prose-mirror>
            {{else}}
              {{{enrichedDANotes}}}
            {{/if}}
          </div>
        </div>

        {{! Known By Tab }}
        <div class='tab' data-tab='knownBy' data-group='info-primary'>
          <div class='back-field'>
            <label class='field-label'>{{localize 'NEONRELIC.InfoCard.KnownBy'}}</label>
            {{#if linkedKnownBy.length}}
              <ul class='linked-doc-list'>
                {{#each linkedKnownBy}}
                  <li class='linked-doc-row'>
                    <img class='linked-doc-img' src='{{this.img}}' alt='{{this.name}}' />
                    <a class='linked-doc-name' data-action='openLinkedDoc' data-uuid='{{this.uuid}}'>{{this.name}}</a>
                    {{#if @root.isEditable}}
                      <button
                        type='button'
                        class='linked-doc-remove'
                        data-action='removeLinkedDoc'
                        data-uuid='{{this.uuid}}'
                        data-tooltip='{{localize "NEONRELIC.NPC.RemoveLinked"}}'
                      >&times;</button>
                    {{/if}}
                  </li>
                {{/each}}
              </ul>
            {{/if}}
            {{#if isEditable}}
              <div class='dropzone' data-drop-key='knownBy'>
                <span class='dropzone-hint'>{{localize 'NEONRELIC.InfoCard.DropNpcHint'}}</span>
              </div>
            {{/if}}
          </div>
        </div>

        {{! Found At Tab }}
        <div class='tab' data-tab='foundAt' data-group='info-primary'>
          <div class='back-field'>
            <label class='field-label'>{{localize 'NEONRELIC.InfoCard.FoundAt'}}</label>
            {{#if linkedFoundAt.length}}
              <ul class='linked-doc-list'>
                {{#each linkedFoundAt}}
                  <li class='linked-doc-row'>
                    <img class='linked-doc-img' src='{{this.img}}' alt='{{this.name}}' />
                    <a class='linked-doc-name' data-action='openLinkedDoc' data-uuid='{{this.uuid}}'>{{this.name}}</a>
                    {{#if @root.isEditable}}
                      <button
                        type='button'
                        class='linked-doc-remove'
                        data-action='removeLinkedDoc'
                        data-uuid='{{this.uuid}}'
                        data-tooltip='{{localize "NEONRELIC.NPC.RemoveLinked"}}'
                      >&times;</button>
                    {{/if}}
                  </li>
                {{/each}}
              </ul>
            {{/if}}
            {{#if isEditable}}
              <div class='dropzone' data-drop-key='foundAt'>
                <span class='dropzone-hint'>{{localize 'NEONRELIC.InfoCard.DropLocationHint'}}</span>
              </div>
            {{/if}}
          </div>
        </div>
      </div>

      {{! Revealed Toggle }}
      <div class='back-field revealed-row'>
        <label class='radio-label'>
          <input type='checkbox' name='system.revealed' {{checked system.revealed}} {{disabled (not isEditable)}} />
          {{localize 'NEONRELIC.InfoCard.Revealed'}}
        </label>
      </div>
    </div>
  {{/if}}
</div>