<header class='item-header flexrow'>
  <img class='item-img' src='{{item.img}}' data-edit='img' title='{{item.name}}' />
  <div class='header-fields'>
    <h1>
      <input
        name='name'
        type='text'
        value='{{item.name}}'
        placeholder='{{localize "NEONRELIC.Item.Name"}}'
        {{disabled (not isEditable)}}
      />
    </h1>
    <span class='item-type'>{{localize (concat 'NEONRELIC.ItemType.' itemType)}}</span>
  </div>
</header>