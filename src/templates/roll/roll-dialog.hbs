<div class='nr-roll-dialog'>
  {{! Attribute }}
  <div class='form-group'>
    <label>{{localize 'NEONRELIC.Roll.Attribute'}}</label>
    <select name='attribute'>
      <option value=''>— {{localize 'NEONRELIC.Roll.None'}} —</option>
      {{#each attributes as |label key|}}
        <option value='{{key}}' {{selected key @root.attribute}}>{{localize label}}</option>
      {{/each}}
    </select>
    <input type='number' name='attributeValue' value='{{attributeValue}}' min='0' max='5' />
  </div>

  {{! Skill }}
  <div class='form-group'>
    <label>{{localize 'NEONRELIC.Roll.Skill'}}</label>
    <select name='skill'>
      <option value=''>— {{localize 'NEONRELIC.Roll.None'}} —</option>
      {{#each skills as |data key|}}
        <option value='{{key}}' {{selected key @root.skill}}>{{localize data.label}}</option>
      {{/each}}
    </select>
    <input type='number' name='skillValue' value='{{skillValue}}' min='0' max='5' />
  </div>

  {{! Gear Bonus — dropdown if items available, otherwise manual }}
  <div class='form-group'>
    <label>{{localize 'NEONRELIC.Roll.GearBonus'}}</label>
    {{#if gearItems.length}}
      <select name='gearBonus' class='gear-select'>
        <option value='0'>— {{localize 'NEONRELIC.Roll.None'}} —</option>
        {{#each gearItems}}
          <option value='{{this.bonus}}'>{{this.name}} (+{{this.bonus}})</option>
        {{/each}}
      </select>
    {{else}}
      <input type='number' name='gearBonus' value='{{gearBonus}}' min='0' />
    {{/if}}
  </div>

  {{! Modifier }}
  <div class='form-group'>
    <label>{{localize 'NEONRELIC.Roll.Modifier'}}</label>
    <input type='number' name='modifier' value='{{modifier}}' />
  </div>

  {{! Difficulty }}
  <div class='form-group'>
    <label>{{localize 'NEONRELIC.Roll.Difficulty'}}</label>
    <input type='number' name='difficulty' value='{{difficulty}}' min='0' max='5' />
  </div>

  {{! Total Pool }}
  <div class='form-group pool-total'>
    <label>{{localize 'NEONRELIC.Roll.TotalPool'}}</label>
    <span class='pool-value'>{{totalPool}}</span>
  </div>

  {{! Talents }}
  {{#if talentItems.length}}
    <div class='form-group roll-talents'>
      <label>{{localize 'NEONRELIC.Roll.Talents'}}</label>
      <div class='talent-list'>
        {{#each talentItems}}
          <div class='roll-talent-entry' title='{{this.description}}'>
            <span class='roll-talent-name'>{{this.name}}</span>
            {{#if this.bonus}}<span class='roll-talent-bonus'>+{{this.bonus}}</span>{{/if}}
          </div>
        {{/each}}
      </div>
    </div>
  {{/if}}

  {{! Notes }}
  <div class='form-group'>
    <label>{{localize 'NEONRELIC.Roll.Notes'}}</label>
    <input type='text' name='notes' value='{{notes}}' placeholder='{{localize "NEONRELIC.Roll.NotesPlaceholder"}}' />
  </div>
</div>