<div class='nr-roll-dialog'>

  {{! ── Header ── }}
  <header class='nr-roll-dialog__header'>
    <span class='nr-roll-dialog__dossier-label'>{{localize 'NEONRELIC.Roll.DossierLabel'}}</span>
    <h2 class='nr-roll-dialog__title'>{{localize 'NEONRELIC.Roll.ConfigTitle'}}</h2>
  </header>

  {{! ── Attribute & Skill (side-by-side) ── }}
  <div class='nr-roll-dialog__stat-row'>
    <div class='nr-roll-dialog__stat'>
      <label class='nr-field-label'>{{localize 'NEONRELIC.Roll.Attribute'}}</label>
      {{#if isLocked}}
        <div class='nr-field-locked'>
          <span class='nr-field-locked__label'>{{lockedAttrLabel}}</span>
          <span class='nr-field-locked__value'>{{attributeValue}}</span>
        </div>
        <input type='hidden' name='attribute' value='{{attribute}}' />
        <input type='hidden' name='attributeValue' value='{{attributeValue}}' />
      {{else}}
        <div class='nr-field-combo'>
          <select name='attribute' class='nr-field-select'>
            <option value=''>— {{localize 'NEONRELIC.Roll.None'}} —</option>
            {{#each attributes as |label key|}}
              <option value='{{key}}' {{selected key @root.attribute}}>{{localize label}}</option>
            {{/each}}
          </select>
          <span class='nr-field-combo__sep'>@</span>
          <input type='number' name='attributeValue' value='{{attributeValue}}' min='0' max='5' class='nr-field-num' />
        </div>
      {{/if}}
    </div>
    <div class='nr-roll-dialog__stat'>
      <label class='nr-field-label'>{{localize 'NEONRELIC.Roll.Skill'}}</label>
      {{#if isLocked}}
        <div class='nr-field-locked'>
          <span class='nr-field-locked__label'>{{lockedSkillLabel}}</span>
          <span class='nr-field-locked__value'>{{skillValue}}</span>
        </div>
        <input type='hidden' name='skill' value='{{skill}}' />
        <input type='hidden' name='skillValue' value='{{skillValue}}' />
      {{else}}
        <div class='nr-field-combo'>
          <select name='skill' class='nr-field-select'>
            <option value=''>— {{localize 'NEONRELIC.Roll.None'}} —</option>
            {{#each skills as |data key|}}
              <option value='{{key}}' {{selected key @root.skill}}>{{localize data.label}}</option>
            {{/each}}
          </select>
          <span class='nr-field-combo__sep'>@</span>
          <input type='number' name='skillValue' value='{{skillValue}}' min='0' max='5' class='nr-field-num' />
        </div>
      {{/if}}
    </div>
  </div>

  {{! ── Gear Bonus ── }}
  <div class='nr-roll-dialog__field'>
    <label class='nr-field-label'>{{localize 'NEONRELIC.Roll.GearBonus'}}</label>
    {{#if gearItems.length}}
      <select name='gearItemId' class='nr-field-select nr-field-select--full'>
        <option value=''>— {{localize 'NEONRELIC.Roll.None'}} —</option>
        {{#each gearItems}}
          <option value='{{this.id}}' data-bonus='{{this.bonus}}'>{{this.name}} (+{{this.bonus}})</option>
        {{/each}}
      </select>
    {{else}}
      <input type='number' name='gearBonus' value='{{gearBonus}}' min='0' class='nr-field-num nr-field-num--wide' />
    {{/if}}
  </div>

  {{! ── Modifier & Difficulty (side-by-side) ── }}
  <div class='nr-roll-dialog__stat-row'>
    <div class='nr-roll-dialog__stat'>
      <label class='nr-field-label'>{{localize 'NEONRELIC.Roll.Modifier'}}</label>
      <input type='number' name='modifier' value='{{modifier}}' class='nr-field-num nr-field-num--large' />
    </div>
    <div class='nr-roll-dialog__stat'>
      <label class='nr-field-label'>{{localize 'NEONRELIC.Roll.Difficulty'}}</label>
      <input
        type='number'
        name='difficulty'
        value='{{difficulty}}'
        min='1'
        max='5'
        class='nr-field-num nr-field-num--large'
      />
    </div>
  </div>

  {{! ── Pool Total ── }}
  <div class='nr-roll-dialog__pool'>
    <div class='nr-roll-dialog__pool-badge'>
      <span class='nr-roll-dialog__pool-label'>{{localize 'NEONRELIC.Roll.TotalPool'}}</span>
      <span class='nr-roll-dialog__pool-value'>{{totalPool}}</span>
    </div>
    <div class='nr-roll-dialog__pool-detail'>
      <span class='nr-pool-chip nr-pool-chip--base'>{{localize 'NEONRELIC.Roll.BaseDice'}}: {{attributeValue}}</span>
      <span class='nr-pool-plus'>+</span>
      <span class='nr-pool-chip nr-pool-chip--skill'>{{localize 'NEONRELIC.Roll.SkillDice'}}: {{skillValue}}</span>
      {{#if gearBonus}}
        <span class='nr-pool-plus'>+</span>
        <span class='nr-pool-chip nr-pool-chip--gear'>{{localize 'NEONRELIC.Roll.GearDice'}}: {{gearBonus}}</span>
      {{/if}}
      {{#if modifier}}
        <span class='nr-pool-mod'>{{modifier}}</span>
      {{/if}}
    </div>
  </div>

  {{! ── Talents ── }}
  {{#if talentItems.length}}
    <div class='nr-roll-dialog__field'>
      <label class='nr-field-label'>{{localize 'NEONRELIC.Roll.Talents'}}</label>
      <div class='nr-talent-list'>
        {{#each talentItems}}
          <div class='nr-talent-chip' title='{{this.description}}'>
            <span class='nr-talent-chip__name'>{{this.name}}</span>
            {{#if this.bonus}}<span class='nr-talent-chip__bonus'>+{{this.bonus}}</span>{{/if}}
          </div>
        {{/each}}
      </div>
    </div>
  {{/if}}

  {{! ── Notes ── }}
  <div class='nr-roll-dialog__field'>
    <label class='nr-field-label'>{{localize 'NEONRELIC.Roll.Notes'}}</label>
    <input
      type='text'
      name='notes'
      value='{{notes}}'
      class='nr-field-text'
      placeholder='{{localize "NEONRELIC.Roll.NotesPlaceholder"}}'
    />
  </div>

</div>