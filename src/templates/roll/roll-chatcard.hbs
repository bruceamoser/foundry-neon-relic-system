{{! Roll result chat card }}
<div class='nr-roll-card' data-actor-id='{{actorId}}'>

  {{! ── Header ── }}
  <header class='nr-roll-card__header'>
    <h3 class='nr-roll-card__title'>
      {{#if skillLabel}}{{skillLabel}}{{else}}{{attributeLabel}}{{/if}}
    </h3>
    {{#if skillLabel}}
      <span class='nr-roll-card__subtitle'>{{attributeLabel}}</span>
    {{/if}}
  </header>

  {{! ── Pool Summary Bar ── }}
  <div class='nr-roll-card__pool-bar'>
    <div class='nr-roll-card__pool-total'>
      <span class='nr-roll-card__pool-label'>{{localize 'NEONRELIC.Roll.Pool'}}</span>
      <span class='nr-roll-card__pool-value'>{{totalPool}}</span>
    </div>
    <div class='nr-roll-card__pool-breakdown'>
      {{#if baseCount}}<span class='nr-pool-chip nr-pool-chip--base'>{{localize 'NEONRELIC.Roll.BaseDice'}}: {{baseCount}}</span>{{/if}}
      {{#if skillCount}}<span class='nr-pool-chip nr-pool-chip--skill'>{{localize 'NEONRELIC.Roll.SkillDice'}}: {{skillCount}}</span>{{/if}}
      {{#if gearCount}}<span class='nr-pool-chip nr-pool-chip--gear'>{{localize 'NEONRELIC.Roll.GearDice'}}: {{gearCount}}</span>{{/if}}
    </div>
  </div>

  {{! ── Dice Groups ── }}
  <div class='nr-roll-card__dice-groups'>
    {{#if baseDice.length}}
      <div class='nr-dice-group nr-dice-group--base'>
        <span class='nr-dice-group__label'>{{localize 'NEONRELIC.Roll.BaseDice'}}</span>
        <div class='nr-dice-group__dice'>
          {{#each baseDice}}
            <span class='{{dieClass "nr-die nr-die--base" this.success}}'>{{this.value}}</span>
          {{/each}}
        </div>
      </div>
    {{/if}}
    {{#if skillDice.length}}
      <div class='nr-dice-group nr-dice-group--skill'>
        <span class='nr-dice-group__label'>{{localize 'NEONRELIC.Roll.SkillDice'}}</span>
        <div class='nr-dice-group__dice'>
          {{#each skillDice}}
            <span class='{{dieClass "nr-die nr-die--skill" this.success}}'>{{this.value}}</span>
          {{/each}}
        </div>
      </div>
    {{/if}}
    {{#if gearDice.length}}
      <div class='nr-dice-group nr-dice-group--gear'>
        <span class='nr-dice-group__label'>{{localize 'NEONRELIC.Roll.GearDice'}}</span>
        <div class='nr-dice-group__dice'>
          {{#each gearDice}}
            <span class='{{dieClass "nr-die nr-die--gear" this.success}}'>{{this.value}}</span>
          {{/each}}
        </div>
      </div>
    {{/if}}
  </div>

  {{! ── Result Panel ── }}
  <div class='nr-roll-card__result {{ternary isSuccess "nr-roll-card__result--pass" (ternary isFailure "nr-roll-card__result--fail" "")}}'>
    <div class='nr-roll-card__result-row'>
      <div class='nr-roll-card__success-count'>
        <span class='nr-roll-card__success-icon'>✦</span>
        <span class='nr-roll-card__success-num'>{{successes}}</span>
        <span class='nr-roll-card__success-label'>{{localize 'NEONRELIC.Roll.Successes'}}</span>
      </div>
      {{#if difficulty}}
        <div class='nr-roll-card__difficulty'>
          <span class='nr-roll-card__diff-label'>vs</span>
          <span class='nr-roll-card__diff-num'>{{difficulty}}</span>
        </div>
        <div class='nr-roll-card__verdict {{ternary isSuccess "nr-roll-card__verdict--pass" "nr-roll-card__verdict--fail"}}'>
          {{#if isSuccess}}{{localize 'NEONRELIC.Roll.Success'}}{{else}}{{localize 'NEONRELIC.Roll.Failure'}}{{/if}}
        </div>
      {{/if}}
    </div>
    {{#if stuntPoints}}
      <div class='nr-roll-card__stunt-bar'>
        <span class='nr-stunt-icon'>⚡</span>
        <span class='nr-stunt-text'>
          <strong>{{stuntPoints}}</strong> {{localize 'NEONRELIC.Stunt.Available'}}
        </span>
      </div>
    {{/if}}
  </div>

  {{! ── Gear Damage Notice ── }}
  {{#if gearDamage}}
    <div class='nr-roll-card__gear-damage {{ternary gearDamage.isBroken "nr-roll-card__gear-damage--broken" ""}}'>
      <span class='nr-gear-damage-icon'>🔧</span>
      <div class='nr-gear-damage-info'>
        <span class='nr-gear-damage-label'>{{localize 'NEONRELIC.Roll.GearDamaged'}}</span>
        <span class='nr-gear-damage-item'>{{gearDamage.itemName}}
          {{#if gearDamage.isBroken}}
            — <strong>{{localize 'NEONRELIC.Roll.GearBroken'}}</strong>
          {{else}}
            ({{localize 'NEONRELIC.Roll.GearBonus'}}: {{gearDamage.newBonus}})
          {{/if}}
        </span>
      </div>
    </div>
  {{/if}}

  {{! ── Ammo Die ── }}
  {{#if ammoDieResult}}
    <div class='nr-roll-card__ammo {{ternary ammoDieResult.stepped "nr-roll-card__ammo--depleted" ""}}'>
      <span class='nr-ammo-icon'>🔫</span>
      <div class='nr-ammo-info'>
        <span class='nr-ammo-label'>{{ammoDieResult.weaponName}} — {{localize 'NEONRELIC.Weapon.AmmoDie'}} ({{ammoDieResult.die}})</span>
        {{#if ammoDieResult.stepped}}
          <span class='nr-ammo-result nr-ammo-result--bad'>Rolled 1 — {{localize 'NEONRELIC.Weapon.AmmoDepleted'}}! Now {{ammoDieResult.newDie}}</span>
        {{else}}
          <span class='nr-ammo-result'>Rolled {{ammoDieResult.roll}} — no effect</span>
        {{/if}}
      </div>
    </div>
  {{/if}}

  {{! ── Push ── }}
  {{#if canPush}}
    <div class='nr-roll-card__actions'>
      <button
        type='button'
        class='nr-push-btn'
        data-action='pushRoll'
        data-actor-id='{{actorId}}'
        data-attribute='{{attributeKey}}'
        data-previous-rolls='{{previousRolls}}'
        data-pool='{{poolData}}'
      >
        <i class='fa-solid fa-dice'></i>
        <span>{{localize 'NEONRELIC.Roll.Push'}}</span>
      </button>
      <span class='nr-push-cost'>+1 {{localize 'NEONRELIC.Corruption.Label'}}</span>
    </div>
  {{/if}}
  {{#if isPush}}
    <div class='nr-roll-card__push-note'>
      <em>{{localize 'NEONRELIC.Roll.PushNote'}}</em>
    </div>
  {{/if}}

  {{! ── Notes ── }}
  {{#if notes}}
    <div class='nr-roll-card__notes'>
      <span class='nr-notes-label'>{{localize 'NEONRELIC.Roll.Notes'}}:</span>
      <span class='nr-notes-text'>{{notes}}</span>
    </div>
  {{/if}}

</div>